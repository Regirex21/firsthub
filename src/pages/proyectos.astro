---
/* Importa layout principal */
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Projects | FIRSTHub">

  <!-- ================================================= -->
  <!-- HERO PRINCIPAL                                    -->
  <!-- ================================================= -->
  <section class="max-w-6xl mx-auto px-6 pt-12 pb-12 text-center">

    <p class="text-sm uppercase tracking-widest text-[#ff8c42] font-semibold">
      &lt;/ Aprende • Construye • Compite /&gt;
    </p>

    <h1 class="text-5xl md:text-7xl font-bold mt-4 text-[#fbfff1]">
      Proyectos
    </h1>

    <p class="text-lg md:text-xl text-white/70 max-w-3xl mx-auto mt-6 leading-relaxed">
      Herramientas, documentación, programas y recursos creados para fortalecer
      equipos FIRST y acelerar crecimiento técnico.
    </p>

  </section>


  <!-- ================================================= -->
  <!-- GRID DE PROYECTOS                                -->
  <!-- ================================================= -->
  <section class="max-w-6xl mx-auto px-6 pb-16 grid md:grid-cols-2 lg:grid-cols-3 gap-6">

    <!-- 1 -->
    <div class="p-6 rounded-2xl bg-[#313553] border border-white/10">
      <p class="text-sm text-[#48a9a6] uppercase tracking-widest">
        Plataforma
      </p>

      <h3 class="text-2xl font-semibold mt-3 text-[#fbfff1]">
        FIRSTHub Website
      </h3>

      <p class="mt-3 text-white/70 leading-relaxed">
        Sitio principal con branding, comunidad y acceso centralizado
        a recursos.
      </p>

      <p class="mt-5 text-sm text-[#ff8c42]">
        Estado: Activo
      </p>
    </div>


    <!-- 2 -->
    <div class="p-6 rounded-2xl bg-[#313553] border border-white/10">
      <p class="text-sm text-[#48a9a6] uppercase tracking-widest">
        Educación
      </p>

      <h3 class="text-2xl font-semibold mt-3 text-[#fbfff1]">
        FIRSTHub Docs
      </h3>

      <p class="mt-3 text-white/70 leading-relaxed">
        Centro de documentación técnica para FRC, FTC,
        liderazgo y mentoría.
      </p>

      <p class="mt-5 text-sm text-[#ff8c42]">
        Estado: En desarrollo
      </p>
    </div>


    <!-- 3 -->
    <div class="p-6 rounded-2xl bg-[#313553] border border-white/10">
      <p class="text-sm text-[#48a9a6] uppercase tracking-widest">
        Formación
      </p>

      <h3 class="text-2xl font-semibold mt-3 text-[#fbfff1]">
        Capacitación de Mentores
      </h3>

      <p class="mt-3 text-white/70 leading-relaxed">
        Sistemas de capacitación para mentores técnicos
        y líderes de equipos.
      </p>

      <p class="mt-5 text-sm text-[#ff8c42]">
        Estado: En desarrollo
      </p>
    </div>

    <!-- 4 -->
    <div class="p-6 rounded-2xl bg-[#313553] border border-white/10">
      <p class="text-sm text-[#48a9a6] uppercase tracking-widest">
        Formación
      </p>

      <h3 class="text-2xl font-semibold mt-3 text-[#fbfff1]">
        Capacitación de Voluntarios
      </h3>

      <p class="mt-3 text-white/70 leading-relaxed">
        Sistemas de capacitación para voluntarios,
        trabajo en los eventos y operación eficiente.
      </p>

      <p class="mt-5 text-sm text-[#ff8c42]">
        Estado: En desarrollo
      </p>
    </div>


    <!-- 5 -->
    <div class="p-6 rounded-2xl bg-[#313553] border border-white/10">
      <p class="text-sm text-[#48a9a6] uppercase tracking-widest">
        FRC
      </p>

      <h3 class="text-2xl font-semibold mt-3 text-[#fbfff1]">
        Manual de Programación y Electrónica FRC
      </h3>

      <p class="mt-3 text-white/70 leading-relaxed">
        Guía integral de WPILib, Git, CAN bus, roboRIO,
        PDH/PDP, cableado y diagnóstico competitivo.
      </p>

      <p class="mt-5 text-sm text-[#ff8c42]">
        Estado: En desarrollo
      </p>
    </div>


    <!-- 6 -->
    <div class="p-6 rounded-2xl bg-[#313553] border border-white/10">
      <p class="text-sm text-[#48a9a6] uppercase tracking-widest">
        FTC
      </p>

      <h3 class="text-2xl font-semibold mt-3 text-[#fbfff1]">
        Manual de Programación y Electrónica FTC
      </h3>

      <p class="mt-3 text-white/70 leading-relaxed">
        Formación en Java, FTC SDK, Control Hub,
        sensores, cableado y troubleshooting.
      </p>

      <p class="mt-5 text-sm text-[#ff8c42]">
        Estado: En desarrollo
      </p>
    </div>


    <!-- 7 -->
    <div class="p-6 rounded-2xl bg-[#313553] border border-white/10">
      <p class="text-sm text-[#48a9a6] uppercase tracking-widest">
        Multimedia
      </p>

      <h3 class="text-2xl font-semibold mt-3 text-[#fbfff1]">
        Recursos en Video
      </h3>

      <p class="mt-3 text-white/70 leading-relaxed">
        Tutoriales, explicaciones y material visual
        para aprendizaje accesible.
      </p>

      <p class="mt-5 text-sm text-[#ff8c42]">
        Estado: En desarrollo
      </p>
    </div>

  </section>

</MainLayout>