---
/* Importa layout principal */
import MainLayout from "../layouts/MainLayout.astro";
---

<!-- ================================================= -->
<!-- CONTACT PAGE                                      -->
<!-- Página para networking y colaboraciones           -->
<!-- ================================================= -->
<MainLayout title="Contact | FIRSTHub">

  <!-- HERO -->
  <section class="max-w-6xl mx-auto px-6 pt-12 pb-12 text-center">

    <p class="text-sm uppercase tracking-widest text-[#ff8c42] font-semibold">
      Construyamos algo grande
    </p>

    <h1 class="text-5xl md:text-7xl font-bold mt-4 text-[#fbfff1]">
      Contacto
    </h1>

    <p class="text-lg md:text-xl text-white/70 max-w-3xl mx-auto mt-6 leading-relaxed">
      FIRSTHub está abierto a colaboraciones, alianzas estratégicas,
      mentoría, proyectos y nuevas oportunidades.
    </p>

  </section>


<!-- GRID DE CONTACTO -->
<section class="max-w-6xl mx-auto px-6 pb-16 flex flex-wrap justify-center gap-6">

  <!-- WHATSAPP -->
  <a
    href="https://chat.whatsapp.com/LmUwj6dra1pDLwkQvoD6vY"
    target="_blank"
    class="w-full md:w-[420px] p-6 rounded-2xl bg-[#313553] border border-white/10 transition duration-300 hover:border-[#25D366] hover:-translate-y-1"
  >
    <p class="text-sm text-[#48a9a6] uppercase tracking-widest">
      Comunidad
    </p>

    <h3 class="text-2xl font-semibold mt-3 text-[#fbfff1]">
      WhatsApp
    </h3>

    <p class="mt-3 text-white/70 leading-relaxed">
      Únete a la comunidad FIRSTHub y conecta con estudiantes,
      equipos y oportunidades.
    </p>
  </a>

  <!-- INSTAGRAM -->
  <a
    href="https://www.instagram.com/_firsthub/"
    target="_blank"
    class="w-full md:w-[420px] p-6 rounded-2xl bg-[#313553] border border-white/10 transition duration-300 hover:border-[#ff8c42] hover:-translate-y-1"
  >
    <p class="text-sm text-[#48a9a6] uppercase tracking-widest">
      Marca
    </p>

    <h3 class="text-2xl font-semibold mt-3 text-[#fbfff1]">
      Instagram
    </h3>

    <p class="mt-3 text-white/70 leading-relaxed">
      Noticias, contenido, anuncios y crecimiento del proyecto.
    </p>
  </a>

</section>

<!-- CTA FINAL -->
<section class="max-w-4xl mx-auto px-6 pb-20 text-center">

  <h2 class="text-3xl md:text-5xl font-bold text-[#fbfff1]">
    Las mejores oportunidades comienzan con una conversación.
  </h2>

  <p class="mt-6 text-white/70 text-lg">
    Si compartes visión, disciplina y ganas de construir,
    probablemente debemos hablar.
  </p>

</section>

</MainLayout>