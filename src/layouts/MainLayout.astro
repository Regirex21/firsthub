---
import "../styles/global.css";

const { title = "FIRSTHub" } = Astro.props;
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>

<body class="bg-[#2a2d43] text-white min-h-screen flex flex-col">

  <!-- ================================================= -->
  <!-- HEADER / NAVBAR                                   -->
  <!-- ================================================= -->
  <header class="border-b border-white/10">

    <nav class="max-w-6xl mx-auto px-6 py-4">

      <!-- FILA PRINCIPAL -->
      <div class="flex items-center justify-between">

        <!-- LOGO -->
        <a href="/" class="text-2xl font-bold text-[#fbfff1]">
          FIRSTHub
        </a>

        <!-- MENÚ DESKTOP -->
        <div class="hidden md:flex gap-6 text-sm font-medium">

          <a href="/" class="hover:text-[#ff8c42] transition">
            Inicio
          </a>

          <a href="/proyectos" class="hover:text-[#ff8c42] transition">
            Proyectos
          </a>

          <!-- DOCS EXTERNO -->
          <a
            href="firsthub-docs.vercel.app"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[#ff8c42] transition flex items-center gap-1"
          >
            Docs 
          </a>

          <a href="/equipo" class="hover:text-[#ff8c42] transition">
            Equipo
          </a>

          <a href="/contacto" class="hover:text-[#ff8c42] transition">
            Contacto
          </a>

        </div>

        <!-- BOTÓN HAMBURGUESA -->
        <button
          id="menu-btn"
          class="md:hidden text-3xl text-[#fbfff1]"
          aria-label="Abrir menú"
        >
          ☰
        </button>

      </div>

      <!-- MENÚ MOBILE -->
      <div
        id="mobile-menu"
        class="hidden md:hidden mt-4 flex flex-col gap-3 text-sm font-medium"
      >

        <a href="/" class="py-2 border-b border-white/10">
          Inicio
        </a>

        <a href="/proyectos" class="py-2 border-b border-white/10">
          Proyectos
        </a>

        <!-- DOCS EXTERNO MOBILE -->
        <a
          href="firsthub-docs.vercel.app"
          target="_blank"
          rel="noopener noreferrer"
          class="py-2 border-b border-white/10"
        >
          Docs 
        </a>

        <a href="/equipo" class="py-2 border-b border-white/10">
          Equipo
        </a>

        <a href="/contacto" class="py-2">
          Contacto
        </a>

      </div>

    </nav>

  </header>

  <!-- CONTENIDO -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="border-t border-white/10 mt-20">
    <div class="max-w-6xl mx-auto px-6 py-8 text-sm text-white/50">
      © 2026 FIRSTHub. &lt;/ Aprende • Construye • Compite /&gt;
    </div>
  </footer>

  <!-- SCRIPT MENU -->
  <script>
    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");

    if (btn && menu) {
      btn.addEventListener("click", () => {
        menu.classList.toggle("hidden");
      });
    }
  </script>

</body>
</html>